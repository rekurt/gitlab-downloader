{
  "name": "gitlab-dump-desktop",
  "version": "0.1.0",
  "description": "Desktop application for GitLab repository management and migration",
  "main": "main.js",
  "homepage": "./",
  "author": "GitLab Dump Team",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run webpack-dev\" \"npm run electron-dev\"",
    "dev": "concurrently \"npm run webpack-dev\" \"npm run electron-dev\"",
    "webpack-dev": "webpack serve --mode development",
    "electron-dev": "wait-on http://localhost:8000 && electron . --remote-debugging-port=9222",
    "build": "webpack --mode production",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist-win": "npm run build && electron-builder --win",
    "dist-mac": "npm run build && electron-builder --mac",
    "dist-linux": "npm run build && electron-builder --linux",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@gitlab-dump/core": "file:../lib",
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "style-loader": "^3.3.0",
    "wait-on": "^7.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
