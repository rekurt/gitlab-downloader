{
  "name": "gitlab-dump-desktop",
  "version": "0.1.0",
  "description": "Desktop application for GitLab repository management and migration",
  "main": "main.js",
  "homepage": "./",
  "author": "GitLab Dump Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run webpack-dev\" \"npm run electron-dev\"",
    "webpack-dev": "webpack serve --mode development",
    "electron-dev": "wait-on http://localhost:8080 && electron . --remote-debugging-port=9222",
    "build": "webpack --mode production",
    "build-python": "python ../build/create_python_binary.py",
    "embed-python": "NODE_PATH=./node_modules node ../build/embed_python_binary.js",
    "prebuild-portable": "npm run build && npm run embed-python",
    "pack": "electron-builder --dir",
    "dist": "npm run prebuild-portable && electron-builder",
    "dist-win": "npm run prebuild-portable && electron-builder --win",
    "dist-mac": "npm run prebuild-portable && electron-builder --mac",
    "dist-linux": "npm run prebuild-portable && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "fs-extra": "^11.1.0",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.0",
    "wait-on": "^7.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
